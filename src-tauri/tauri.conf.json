{
  "productName": "FontConverter",
  "version": "1.4.0",
  "identifier": "com.fontconverter.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "popup",
        "title": "FontConverter",
        "width": 420,
        "height": 520,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": false,
        "skipTaskbar": true,
        "center": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "global-shortcut": null,
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJBRjY2RUMxRUI3OTQ5QTAKUldTZ1NYbnJ3VzcydWx4OVNYcXNvc3pPaTUzZFdlTGdGZUN0L2RYanZOYmxHMG8rWlVTUkhpU1QK",
      "endpoints": [
        "https://github.com/leva-nilla/Windows-TextFont-Conveter/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
